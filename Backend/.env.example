# Machine Memory backend environment example
# Copy this file to .env and replace the placeholder values.
# Never commit real API keys or credentials.

# Required for Analyze with AI and Deep Review direct watsonx.ai model calls.
WATSONX_API_KEY=your_ibm_watsonx_api_key_secret
WATSONX_PROJECT_ID=your_watsonx_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Optional legacy/debug watsonx Orchestrate values.
ORCHESTRATE_HOST_URL=https://api.au-syd.watson-orchestrate.cloud.ibm.com/instances/your_orchestrate_instance_id
ORCHESTRATE_AGENT_ID=your_orchestrate_agent_id
